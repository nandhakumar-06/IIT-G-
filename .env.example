# Copy this file as .env in the backend folder root (same level as backend/config.py)
# and fill the values below.

# Core app
SECRET_KEY=change-this-to-a-long-random-secret
TEST_MODE=False

# SMTP (OTP + reset mail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-mailbox@example.com
SMTP_PASSWORD=your-app-password-or-smtp-password
EMAIL_FROM=IIT-G Mark Sender <your-mailbox@example.com>

# Optional
COUNTRY_CODE=91
